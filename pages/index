              <button style={Z.del} onClick={()=>dMI(mi.id)}>✕</button>
            </div>);
          })}
          {sm.items.length===0&&<div style={Z.emp}><div style={Z.emT}>No ingredients</div></div>}
        </div>)}

        {vw==="add"&&(<div>
          <h2 style={{fontSize:16,fontWeight:800,marginBottom:12}}>Add to List</h2>
          <label style={Z.lb}>Name</label><input style={Z.inp} placeholder="Item name" value={fN} onChange={e=>sfN(e.target.value)} autoFocus/>
          <label style={Z.lb}>Category</label>
          <div style={Z.cG}>{CATS.map(c=><button key={c.id} style={{...Z.cBtn,...(fC===c.id?{background:c.c+"22",borderColor:c.c,color:c.c}:{})}} onClick={()=>sfC(c.id)}>{c.i} {c.l}</button>)}</div>
          <label style={Z.lb}>Store / Alt Store</label>
          <div style={{display:"flex",gap:5}}><select style={{...Z.inp,flex:1}} value={fSt} onChange={e=>sfSt(e.target.value)}>{stores.map(x=><option key={x} value={x}>{x}</option>)}</select><select style={{...Z.inp,flex:1}} value={fAlt} onChange={e=>sfAlt(e.target.value)}><option value="">No alt</option>{stores.map(x=><option key={x} value={x}>{x}</option>)}</select></div>
          <div style={{display:"flex",gap:6}}><div style={{flex:1}}><label style={Z.lb}>Qty</label><input style={Z.inp} type="number" min="1" value={fQ} onChange={e=>sfQ(e.target.value)}/></div><div style={{flex:1}}><label style={Z.lb}>Unit</label><input style={Z.inp} placeholder="lbs, box..." value={fU} onChange={e=>sfU(e.target.value)}/></div></div>
          <label style={Z.lb}>Notes</label><input style={Z.inp} placeholder="Optional" value={fNt} onChange={e=>sfNt(e.target.value)}/>
          <label style={{display:"flex",alignItems:"center",gap:8,fontSize:12,color:fIa?"#f59e0b":"#64748b",margin:"10px 0 6px",cursor:"pointer"}} onClick={()=>sfIa(!fIa)}>
            <span style={{width:20,height:20,borderRadius:5,border:"2px solid "+(fIa?"#f59e0b":"#475569"),background:fIa?"#f59e0b":"transparent",display:"flex",alignItems:"center",justifyContent:"center",fontSize:11,color:"#fff",fontWeight:700}}>{fIa?"✓":""}</span>
            Inactive - not needed every trip
          </label>
          <div style={{display:"flex",gap:6,marginTop:10}}><button style={Z.pb} onClick={addToList}>Add</button><button style={Z.sb} onClick={()=>sVw("list")}>Cancel</button></div>
        </div>)}
      </div>

      {toast&&<div style={Z.tst}>{toast}</div>}
      <div style={Z.ft}>📡 Syncs in real-time across devices</div>
    </div>
  );
}

